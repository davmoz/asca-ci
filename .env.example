# ============================================================================
# TFS Docker Environment Variables
# ============================================================================
# Copy this file to .env and adjust the values for your deployment.
# SECURITY: Never commit your .env file to version control.
# ============================================================================

# -- MySQL / MariaDB Configuration --
MYSQL_ROOT_PASSWORD=change_me_root_password_here
MYSQL_DATABASE=forgottenserver
MYSQL_USER=forgottenserver
MYSQL_PASSWORD=change_me_strong_password_here
MYSQL_HOST=db
MYSQL_PORT=3306

# -- TFS Server Configuration --
SERVER_IP=127.0.0.1
LOGIN_PORT=7171
GAME_PORT=7172

# -- Rate Limiting --
MAX_PACKETS_PER_SECOND=25
STATUS_TIMEOUT=5000
MAX_PLAYERS=0
